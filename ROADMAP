## Library API

    import "github.com/Destraag/toroidzip/codec"

    opts := codec.EncodeOptions{
        ReanchorInterval: 256,              // 0 = use default
        DriftMode:        codec.DriftReanchor, // A=Reanchor B=Compensate C=Quantize
    }
    err := codec.Encode(values, w, opts)
    values, err := codec.Decode(r)
