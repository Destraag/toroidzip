## Library API

    import "github.com/Destraag/toroidzip/codec"

    // Encode / Decode
    err := codec.Encode(values, w, codec.EncodeOptions{
        EntropyMode:      codec.EntropyLossless,
        DriftMode:        codec.DriftReanchor,
        ReanchorInterval: 256,
    })
    values, err := codec.Decode(r)

    // Analysis
    report := codec.AnalyzeDrift(values, []int{64, 128, 256, 512})
    precision := codec.AnalyzePrecision(values, 0.01) // 1% max relative error
    ratios := codec.ExtractNormalRatios(values, codec.DriftReanchor, 256)

    // Precision conversion
    bits := codec.SigFigsToBits(6)   // 6 sig figs → bit depth
    figs := codec.BitsToSigFigs(20)  // 20 bits → sig figs

